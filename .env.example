# Acharyamul Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_USER=acharyamul
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=acharyamul
DATABASE_URL=postgresql://acharyamul:changeme_strong_password@db:5432/acharyamul

# Google OAuth 2.0
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# JWT
# IMPORTANT: Generate a strong random string for production!
JWT_SECRET=changeme_generate_a_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Dev Admin (only works when APP_ENV=development)
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin123

# App
APP_ENV=production
APP_URL=http://localhost
CORS_ORIGINS=http://localhost

# Backup
BACKUP_RETENTION_DAYS=30
